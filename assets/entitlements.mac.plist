<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime entitlements for the notarized Tauri (WKWebView) build.
         Wired in via bundle.macOS.entitlements in src-tauri/tauri.conf.json. -->

    <!-- Outbound network access for university lookup, geocoding, time sync and
         update checks (see the connect-src allowlist in the app CSP). -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read/write the documents the user picks through the native file dialog. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
