{
  "name": "academia-track",
  "private": true,
  "version": "5.2.2",
  "description": "Academic Application Tracker - Track universities, programs, deadlines, and submissions",
  "author": "BHARATH CHANDRA VADDARAM <bharath.vbcr@gmail.com>",
  "homepage": "https://github.com/bharathvbcr/AcademiaTrack",
  "repository": {
    "type": "git",
    "url": "https://github.com/bharathvbcr/AcademiaTrack.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20 <26"
  },
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit && tsgo -p electron/tsconfig.json --noEmit",
    "dev": "vite",
    "build": "vite build",
    "package": "npm run build:electron",
    "preview": "vite preview",
    "build:main": "tsgo -p electron/tsconfig.json",
    "dev:electron": "npm-run-all --parallel dev start:electron",
    "start:electron": "wait-on http://localhost:3000 && npm run build:main && electron .",
    "build:electron": "npm run build && npm run build:main && electron-builder"
  },
  "build": {
    "appId": "com.bharathvbcr.academiatrack",
    "productName": "AcademiaTrack",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AcademiaTrack"
    }
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "canvas-confetti": "^1.9.3",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.3.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.4.0",
    "npm-run-all": "^4.1.5",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "npm:@typescript/typescript6@^6.0.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.1"
  }
}
