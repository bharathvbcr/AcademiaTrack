{
  "name": "academia-track",
  "private": true,
  "version": "5.5.1",
  "description": "Academic Application Tracker - Track universities, programs, deadlines, and submissions",
  "author": "BHARATH CHANDRA VADDARAM <bharath.vbcr@gmail.com>",
  "homepage": "https://github.com/bharathvbcr/AcademiaTrack",
  "repository": {
    "type": "git",
    "url": "https://github.com/bharathvbcr/AcademiaTrack.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20 <26"
  },
  "scripts": {
    "map:verify": "node scripts/verify-map-coverage.js",
    "map:status": "npm run gitnexus:status && npm run map:verify",
    "map:refresh": "npm run gitnexus:analyze && npm run graphify:hook-status && npm run map:verify",
    "graphify:hook-status": "graphify hook status",
    "gitnexus:status": "npx gitnexus status",
    "gitnexus:analyze": "npx gitnexus analyze",
    "gitnexus:wiki": "npx gitnexus wiki",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "dev": "vite",
    "build": "vite build",
    "package": "npm run build:tauri",
    "preview": "vite preview",
    "dev:desktop": "npm run dev:tauri",
    "build:desktop": "npm run build:tauri",
    "tauri": "tauri",
    "dev:tauri": "tauri dev",
    "build:tauri": "tauri build",
    "build:mac": "tauri build --target universal-apple-darwin"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@hello-pangea/dnd": "^18.0.1",
    "@tauri-apps/api": "^2.11.0",
    "canvas-confetti": "^1.9.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "material-symbols": "^0.45.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.3.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.4.0",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "npm:@typescript/typescript6@^6.0.0",
    "vite": "^6.4.2",
    "vitest": "^4.0.16"
  }
}
