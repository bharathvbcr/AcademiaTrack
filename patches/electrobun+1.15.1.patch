+		message: "*",
+		listener: WildcardRPCMessageHandlerFn<RemoteSchema["messages"]>,
+	): void;
+	function removeMessageListener<
+		M extends keyof RemoteSchema["messages"],
+	>(
+		message: M,
+		listener: RPCMessageHandlerFn<RemoteSchema["messages"], M>,
+	): void;
