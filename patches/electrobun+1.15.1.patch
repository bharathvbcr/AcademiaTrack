+export const quit = () => {
+	if (isQuitting) return;
+	isQuitting = true;
+
+	const beforeQuitEvent = electrobunEventEmitter.events.app.beforeQuit({});
+	electrobunEventEmitter.emitEvent(beforeQuitEvent);
